<IfModule mod_rewrite.c>
    RewriteEngine On

    # Canonicalize URLs that include /public to clean root URLs.
    RewriteRule ^public(?:/(.*))?$ /$1 [R=301,L,NC]

    # Route domain root directly to Laravel front controller.
    RewriteRule ^$ public/index.php [L]

    # Keep direct existing files and directories unchanged.
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Forward everything else to Laravel's public directory.
    RewriteRule ^(.*)$ public/$1 [L]



    
</IfModule>